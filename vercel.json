{
  "version": 3,
  "experimentalServices": {
    "frontend": {
      "src": ".",
      "use": "@vercel/static-build",
      "routePrefix": "/",
      "config": {
        "distDir": "dist"
      }
    },
    "backend": {
      "src": "backend",
      "use": "@vercel/node",
      "routePrefix": "/api",
      "config": {
        "includeFiles": ["backend/**"]
      }
    }
  }
}
